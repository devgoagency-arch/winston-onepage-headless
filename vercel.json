{
    "crons": [
        {
            "path": "/api/warm-cache",
            "schedule": "0 5 * * *"
        }
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "no-store" }
            ]
        },
        {
            "source": "/_astro/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/images/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
            ]
        },
        {
            "source": "/fonts/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/api/sync",
            "headers": [
                { "key": "Access-Control-Allow-Origin", "value": "*" },
                { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
                { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-wc-webhook-signature, x-wc-webhook-topic, x-wc-webhook-resource, x-wc-webhook-event, x-wc-webhook-id" }
            ]
        }
    ]
}
