{
    "crons": [
        {
            "path": "/api/warm-cache",
            "schedule": "0 5 * * *"
        }
    ],
    "headers": [
        {
            "source": "/api/sync",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "POST, OPTIONS"
                }
            ]
        }
    ]
}