---
import { getHomeCategories } from "../lib/categories";

// Obtenemos los datos dinámicos de la sección
const data = await getHomeCategories();

// Si no hay datos (error API), usamos un fallback para mantener la UI
const title = data?.title || "Ropa y zapatos para hombre";
const subtitle =
    data?.subtitle ||
    "Todo lo que necesita el hombre colombiano que viste con criterio. Ropa y cuero artesanal bajo un mismo sello.";
const categories = data?.categories || [];
---

<section class="category-grid">
    <div class="container text-center">
        <div class="category-header">
            <h2 class="category-title" set:html={title} />
            <div class="category-subtitle" set:html={subtitle} />
        </div>

        <div
            class={`grid-layout ${categories.length >= 4 ? "is-grid-4" : "is-flex-centered"}`}
        >
            {
                categories.map((category: any) => (
                    <a
                        href={`/categoria/${category.slug}`}
                        class="category-item"
                    >
                        <div class="category-image-wrapper">
                            <img
                                src={
                                    category.image || "/images/placeholder.jpg"
                                }
                                alt={category.name}
                                class="category-image"
                                loading="lazy"
                            />
                        </div>
                        <h3 class="category-label">{category.name}</h3>
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    .category-grid {
        padding: var(--section-padding-desktop, 2rem 0);
        background-color: #fff;
    }

    .category-header {
        max-width: 800px;
        margin: 0 auto 4rem;
        text-align: center;
    }

    .category-title {
        color: var(--color-green);
        font-size: 1.5rem;
        margin-bottom: 1rem;
        font-family: var(--font-titles);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 4px;
    }

    .category-subtitle {
        color: #666;
        font-size: 0.85rem;
        line-height: 1.6;
        font-family: var(--font-body, "Helvetica", "Arial", sans-serif);
        font-weight: 400;
        max-width: 700px;
        margin: 0 auto;
        text-transform: none;
        letter-spacing: 0.5px;
    }

    .grid-layout {
        max-width: var(--container-max-width, 1400px);
        margin: 0 auto;
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 2rem;
    }

    /* Forzar el grid cuando hay 4 items */
    .grid-layout.is-grid-4 {
        display: grid !important;
        grid-template-columns: repeat(4, 1fr) !important;
        gap: 1.5rem !important;
    }

    .category-item {
        flex: 1 1 250px;
        max-width: 320px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        transition: transform 0.4s ease;
    }

    /* Reset de anchos para el modo grid */
    .is-grid-4 .category-item {
        max-width: none !important;
        flex: none !important;
        width: 100% !important;
    }

    .category-image-wrapper {
        width: 100%;
        aspect-ratio: 3 / 4;
        overflow: hidden;
        margin-bottom: 2rem;
        background-color: #f5f5f5;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

    .category-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .category-item:hover .category-image {
        transform: scale(1.05);
    }

    .category-label {
        font-family: var(--font-titles);
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--color-green);
        margin: 0;
        text-align: center;
        transition: color 0.3s ease;
    }

    .category-item:hover .category-label {
        color: var(--color-beige);
    }

    @media (max-width: 992px) {
        .grid-layout {
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem;
        }

        .category-grid {
            padding: 4rem 1.5rem;
        }
    }

    @media (max-width: 480px) {
        .category-title {
            font-size: 1.5rem;
        }

        .grid-layout {
            gap: 1rem;
        }

        .category-subtitle {
            font-size: 0.9rem;
        }
    }
</style>
