---
// Last update: 2026-03-16 - Deployment Trigger
import { wcFetch } from "../lib/woocommerce";

// Lista de categorías que queremos mostrar con su imagen local fija y palabras clave para búsqueda dinámica
// Lista de categorías que queremos mostrar vinculadas por ID exacto de WordPress
const targetCategories = [
    { id: 249, image: "/images/ropa.jpg", fallbackName: "Ropa" },
    { id: 194, image: "/images/zapatos.jpg", fallbackName: "Botas" },
    { id: 190, image: "/images/maletas.jpg", fallbackName: "Maletas" },
    { id: 126, image: "/images/accesorios.jpg", fallbackName: "Accesorios" },
];

// Obtenemos todas las categorías para poder encontrarlas por ID
const allCategories = (await wcFetch("/products/categories?per_page=100")) || [];

const categoriesData = targetCategories.map((target) => {
    // Buscamos la categoría por ID exacto
    const cat = allCategories.find((c: any) => c.id === target.id);

    return {
        slug: cat?.slug || target.id.toString(),
        name: cat?.name || target.fallbackName,
        image: target.image,
    };
});
---

<section class="category-grid">
    <div class="container text-center">
        <div class="category-header">
            <h2 class="category-title">Ropa y zapatos para hombre</h2>
            <p class="category-subtitle">
                Todo lo que necesita el hombre colombiano que viste con
                criterio. Ropa y cuero artesanal bajo un mismo sello.
            </p>
        </div>

        <div class="grid-layout">
            {
                categoriesData.map((category) => (
                    <a
                        href={`/categoria/${category.slug}`}
                        class="category-item"
                    >
                        <div class="category-image-wrapper">
                            <img
                                src={category.image}
                                alt={category.name}
                                class="category-image"
                                loading="lazy"
                            />
                        </div>
                        <h3 class="category-label">{category.name}</h3>
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    .category-grid {
        padding: 2rem 0;
        background-color: #fff;
    }

    .category-header {
        max-width: 700px;
        margin: 0 auto 2rem;
        text-align: center;
    }

    .category-title {
        color: var(--color-green);
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
        font-family: var(--font-titles);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .category-subtitle {
        color: var(--color-green);
        font-size: 0.8rem;
        line-height: 1.6;
        font-family: var(--font-paragraphs);
        font-weight: 400;
        max-width: 600px;
        margin: 0 auto;
    }

    .grid-layout {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
    }

    .category-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        transition: transform 0.4s ease;
    }

    .category-image-wrapper {
        width: 100%;
        aspect-ratio: 3 / 4;
        overflow: hidden;
        margin-bottom: 1.5rem;
        background-color: #f5f5f5;
    }

    .category-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .category-item:hover .category-image {
        transform: scale(1.05);
    }

    .category-label {
        font-family: var(--font-titles);
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--color-green);
        margin: 0;
        text-align: center;
        transition: color 0.3s ease;
    }

    .category-item:hover .category-label {
        color: var(--color-beige);
    }

    @media (max-width: 992px) {
        .grid-layout {
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem;
        }

        .category-grid {
            padding: 4rem 1.5rem;
        }
    }

    @media (max-width: 480px) {
        .category-title {
            font-size: 1.5rem;
        }

        .grid-layout {
            gap: 1rem;
        }

        .category-subtitle {
            font-size: 0.9rem;
        }
    }
</style>
