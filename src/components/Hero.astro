---

---

<section id="inicio" class="hero">
    <div class="image-background">
        <video
            class="hero-bg-image"
            autoplay
            loop
            muted
            playsinline
            poster="/images/banner-winston-and-harry-maletas.png"
        >
            <source src="/videos/hero-video.mp4" type="video/mp4" />
        </video>
        <div class="overlay"></div>
    </div>

    <div class="hero-content">
        <h1 class="hero-title">
            Ropa y Zapatos de Cuero para Hombre en Colombia, Hechos a Mano y
            Diseñados para Durar.
        </h1>
        <p class="hero-subtitle">
            Camisas, chaquetas, trajes, jeans, zapatos de cuero artesanal,
            maletas y accesorios. Todo bajo un mismo sello colombiano. De pies a
            cabeza.
        </p>
        <div class="hero-actions">
            <a href="/productos" class="btn-primary">Explorar Colección</a>
            <a href="/sobre-nosotros" class="btn-secondary"
                >Conoce Nuestra Historia</a
            >
        </div>
    </div>
</section>

<style>
    .hero {
        position: sticky;
        top: 90px; /* Altura del header en desktop */
        margin-top: 90px; /* Para que no empiece debajo del header fixed */
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background-color: #000;
        z-index: 1;
        transition: top 0.3s ease-in-out;
    }

    :global(body.is-header-hidden) .hero {
        top: 0;
    }

    .image-background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.3); /* Subtler dark overlay */
        z-index: 1;
    }

    .hero-bg-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }

    .hero-content {
        position: relative;
        z-index: 10;
        text-align: center;
        max-width: 900px;
        padding: 0 2rem;
        margin-top: 40vh; /* Adjust position */
        animation: fadeInUp 1.5s ease-out forwards;
    }

    .hero-title {
        font-family: var(--font-titles);
        color: var(--color-white);
        font-size: 1.25rem;
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: 2rem;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .hero-subtitle {
        font-family: var(--font-paragraphs);
        color: var(--color-white);
        font-size: 0.8rem;
        max-width: 700px;
        margin: 0 auto 3.5rem;
        line-height: 1.6;
        text-transform: none;
        letter-spacing: 0.5px;
    }

    .hero-actions {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary {
        display: inline-block;
        padding: 1rem 2.5rem;
        font-family: var(--font-titles);
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: none;
        cursor: pointer;
        min-width: 240px;
        background-color: #155338;
        color: #efefef;
        border-radius: 0;
    }

    .btn-secondary {
        display: inline-block;
        padding: 1rem 2.5rem;
        font-family: var(--font-titles);
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: none;
        cursor: pointer;
        min-width: 240px;
        background-color: var(--color-beige);
        color: #efefef;
        border-radius: 0;
    }

    .btn-primary:hover {
        background-color: var(--color-beige);
        transform: translateY(-3px);
        color: #efefef;
    }

    .btn-secondary:hover {
        background-color: var(--color-green);
        transform: translateY(-3px);
        color: #efefef;
    }

    @keyframes fadeInUp {
        0% {
            opacity: 0;
            transform: translateY(40px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 992px) {
        .hero {
            height: 90vh; /* Better for mobile */
            top: 65px;
            margin-top: 65px;
        }

        .hero-title {
            font-size: 1.25rem;
            margin-bottom: 1.5rem;
        }

        .hero-subtitle {
            margin-bottom: 2.5rem;
        }

        .btn-primary,
        .btn-secondary {
            width: 100%;
            min-width: unset;
        }
    }

    @media (max-width: 480px) {
        .hero-title {
            font-size: 1.15rem;
        }
        .hero-content {
            padding: 0 1.5rem;
            margin-top: 10vh;
        }
    }
</style>
