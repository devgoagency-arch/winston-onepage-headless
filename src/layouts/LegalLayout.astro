---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
    title: string;
    subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<Layout title={title}>
    <Header />
    <main class="legal-page">
        <section class="legal-header">
            <div class="container header-container">
                <h1 class="legal-title">{title}</h1>
                {subtitle && <p class="legal-subtitle" set:html={subtitle} />}
            </div>
        </section>

        <section class="legal-content">
            <div class="container content-container">
                <div class="legal-box">
                    <slot />
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<style>
    .legal-page {
        padding-top: 90px; /* Space for fixed header */
        background-color: #f4f4f4;
    }

    .legal-header {
        background-color: #ebe3d7; /* Refined beige to match image */
        padding: 4rem 2rem;
        text-align: center;
        position: relative;
    }

    .header-container {
        max-width: 950px;
        margin: 0 auto;
        padding: 0rem;
    }

    .legal-title {
        font-size: 1.25rem;
        margin-bottom: 2rem;
        color: var(--color-green);
        letter-spacing: 2px;
        font-family: var(--font-titles);
        font-weight: 700;
        text-transform: uppercase;
    }

    .legal-subtitle {
        max-width: 900px;
        margin: 0 auto;
        font-size: 0.8rem;
        color: #555;
        line-height: 1.6;
        text-transform: none;
        letter-spacing: normal;
        text-align: center;
    }

    .legal-subtitle a {
        color: var(--color-green, #155338);
        text-decoration: underline;
        font-weight: 500;
    }

    .legal-subtitle strong,
    .legal-subtitle b {
        font-weight: 700;
        color: var(--color-black, #121212);
    }

    .legal-content {
        margin-top: 0;
        padding-bottom: 5rem;
        padding-top: 2rem;
        position: relative;
        z-index: 10;
        background-color: #f3efe7;
        width: 100%;
        display: flex;
        justify-content: center;
    }

    .content-container {
        width: 100%;
        max-width: 1200px;
        padding: 0 1rem;
        margin: 0 auto;
    }

    .legal-box {
        background: #ffffff;
        padding: 4rem;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.05);
        border-radius: 4px;
        max-width: 1000px;
        margin: 0 auto;
        width: 100%;
    }

    /* Estilos globales para contenido de WordPress dentro de páginas legales */
    :global(.wp-content) {
        word-break: break-word;
        max-width: 900px;
        margin: 0 auto;
        font-family: var(--font-body, "Helvetica", "Arial", sans-serif);
        text-align: left; /* Aseguramos alineación a la izquierda */
    }

    :global(.wp-content h1),
    :global(.wp-content h2),
    :global(.wp-content h3),
    :global(.wp-content h4) {
        font-family: var(--font-titles, "darkmode-off", "Antonio", sans-serif);
        font-size: 1.25rem;
        margin: 3rem 0 1.5rem;
        color: var(--color-green, #155338);
        border-bottom: 1px solid #f0f0f0;
        padding-bottom: 0.75rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        font-weight: 700;
        display: block;
    }

    :global(.wp-content p) {
        margin-bottom: 1.5rem;
        color: var(--color-black, #121212);
        line-height: 1.8;
        font-size: 0.9rem;
        display: block;
        text-align: left !important;
    }

    :global(.wp-content ul),
    :global(.wp-content ol) {
        margin-bottom: 2rem;
        padding-left: 1.5rem;
        list-style: disc;
    }

    :global(.wp-content li) {
        margin-bottom: 1rem;
        color: var(--color-black, #121212);
        line-height: 1.6;
        font-size: 0.9rem;
    }

    :global(.wp-content strong) {
        color: var(--color-black, #121212);
        font-weight: 700;
    }

    :global(.wp-content a) {
        color: var(--color-beige, #b1915f);
        text-decoration: underline;
        text-underline-offset: 4px;
        transition: opacity 0.3s;
    }

    :global(.wp-content a:hover) {
        opacity: 0.7;
    }

    /* Reset de Elementor */
    :global(.wp-content .elementor-section),
    :global(.wp-content .elementor-container),
    :global(.wp-content .elementor-column),
    :global(.wp-content .elementor-widget-wrap) {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
        display: block !important;
        border: none !important;
    }

    :global(.wp-content .elementor-spacer),
    :global(.wp-content .elementor-divider) {
        display: none !important;
    }

    @media (max-width: 768px) {
        .legal-page {
            padding-top: 80px;
        }

        .legal-header {
            padding: 4rem 1rem 8rem;
        }

        .legal-title {
            font-size: 1.25rem;
            letter-spacing: 0.1em;
        }

        .legal-subtitle {
            font-size: 0.85rem;
        }

        .legal-content {
            margin-top: -4rem;
            padding-bottom: 3rem;
        }

        .legal-box {
            padding: 2rem 1.5rem;
            width: auto;
            margin: 0 1rem;
        }
    }
</style>
