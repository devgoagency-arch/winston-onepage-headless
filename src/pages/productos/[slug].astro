---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ProductDetail from "../../components/ProductDetail";
import { getProductBySlug, getProductsPool } from "../../lib/woocommerce";

export const isr = {
    expiration: 86400, // 24 horas (revalidación forzada vía Webhook)
};

const { slug } = Astro.params;

let product: any = null;
let error: any = null;

try {
    // 1. Fetch usando la nueva utilidad optimizada (REST API v3)
    product = await getProductBySlug(slug as string);
    
    if (product) {
        // --- FETCH RELATED PRODUCTS & FBT ---
        let relatedProducts: any[] = [];
        let fbtProducts: any[] = [];
        
        try {
            // IDs de categorías actualizados según el catálogo actual de W&H
            const shoeCats = [63, 194, 192, 195, 193, 196, 70]; 
            const clothingCats = [249, 951, 952, 251, 1022, 250];        
            const accessoryCats = [126, 172, 190];             
            
            // Usamos el pool de productos con caché de 10 minutos (Optimizado)
            const rawProducts = await getProductsPool();
            
            if (rawProducts && rawProducts.length > 0) {
                // Mapear al formato que espera el frontend (Store API style compatible)
                const allStoreProducts = rawProducts.map((p: any) => {
                    const hasTax = p.tax_status === 'taxable';
                    const rawPrice = parseFloat(p.price || "0");
                    const inclusivePrice = hasTax ? Math.round(rawPrice * 1.19) : Math.round(rawPrice);
                    
                    return {
                        id: p.id,
                        name: p.name,
                        slug: p.slug,
                        permalink: p.permalink,
                        prices: {
                            price: inclusivePrice.toString(),
                            regular_price: p.regular_price ? Math.round(parseFloat(p.regular_price) * (hasTax ? 1.19 : 1)).toString() : "",
                            sale_price: p.sale_price ? Math.round(parseFloat(p.sale_price) * (hasTax ? 1.19 : 1)).toString() : "",
                            currency_prefix: "$",
                            currency_minor_unit: 0
                        },
                        images: p.images.map((img: any) => ({
                            src: img.src,
                            alt: img.alt || p.name
                        })),
                        attributes: p.attributes.map((attr: any) => ({
                            id: attr.id,
                            name: attr.name,
                            terms: attr.options ? attr.options.map((opt: string, idx: number) => ({
                                id: idx,
                                name: opt,
                                slug: opt.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s+/g, '-').replace(/[^\w-]+/g, '')
                            })) : []
                        })),
                        categories: p.categories,
                        variations: null,
                        variation_images_map: null
                    };
                });
                
                const currentCats = product.categories?.map((c: any) => c.id) || [];
                const pName = (product.name || "").toLowerCase();
                
                const isCurrentShoe = currentCats.some((id: any) => shoeCats.includes(id)) || 
                                      pName.includes('zapato') || pName.includes('mocasín') || pName.includes('tenis') || pName.includes('bota');
                
                const isCurrentClothing = currentCats.some((id: any) => clothingCats.includes(id)) || 
                                          pName.includes('chaqueta') || pName.includes('sueter') || pName.includes('suéter') || pName.includes('camisa') || pName.includes('pantalon');

                // 1. Completa tu look (Preferimos relacionados definidos en WC, si no, aleatorios)
                const wcRelatedIds = [...(product.upsell_ids || []), ...(product.related_ids || [])];
                
                if (wcRelatedIds.length > 0) {
                    relatedProducts = allStoreProducts.filter((p: any) => wcRelatedIds.includes(p.id)).slice(0, 4);
                }
                
                if (relatedProducts.length < 4) {
                    const extra = allStoreProducts
                        .filter((p: any) => p.id !== product.id && !relatedProducts.some(rp => rp.id === p.id))
                        .sort(() => Math.random() - 0.5)
                        .slice(0, 4 - relatedProducts.length);
                    relatedProducts = [...relatedProducts, ...extra];
                }

                // 2. El Complemento Ideal (FBT)
                // Si es zapato, sugerimos ropa. Si es ropa, sugerimos zapatos.
                let poolA = allStoreProducts.filter((p: any) => p.id !== product.id && (p.categories?.some((c: any) => shoeCats.includes(c.id))));
                let poolB = allStoreProducts.filter((p: any) => p.id !== product.id && (p.categories?.some((c: any) => clothingCats.includes(c.id))));
                
                if (isCurrentShoe) {
                   fbtProducts = poolB.length > 0 ? [poolB[0]] : [allStoreProducts.find((p: any) => p.id !== product.id)];
                } else {
                   fbtProducts = poolA.length > 0 ? [poolA[0]] : [allStoreProducts.find((p: any) => p.id !== product.id)];
                }
            }
        } catch (e) {
            console.error("Error fetching related products:", e);
        }

        product.fbt_products = fbtProducts.filter(Boolean);

    } else {
        error = "Producto no encontrado en el catálogo";
    }
} catch (e) {
    console.error("Error crítico en [slug].astro:", e);
    error = "Hubo un problema de conexión.";
}

if (!product && !error) {
    return Astro.redirect("/404");
}
---

<Layout title={product ? `${product.name} | Winston & Harry` : "Producto"}>
    <Header />

    <main class="product-page-container">
        {
            product ? (
                <ProductDetail client:load initialProduct={product} />
            ) : (
                <div class="container error-msg">
                    <h1>{error}</h1>
                    <a href="/#tienda" class="btn">
                        Volver a la tienda
                    </a>
                </div>
            )
        }
    </main>

    <Footer />
</Layout>

<style>
    .product-page-container {
        padding-top: 90px;
        min-height: 80vh;
    }
    .error-msg {
        text-align: center;
        padding: 10rem 0;
    }
    h1 {
        margin-bottom: 2rem;
        color: var(--color-green);
    }

    @media (max-width: 768px) {
        .product-page-container {
            padding-top: 65px; /* Espacio para el header fixed */
            min-height: 80vh;
        }
</style>