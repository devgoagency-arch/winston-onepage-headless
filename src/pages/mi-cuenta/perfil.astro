
---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ProfileForm from "../../components/auth/ProfileForm";
---

<Layout title="Mi Perfil | Winston & Harry">
    <Header />

    <main class="account-subpage-container">
        <div class="container">
            <header class="subpage-header">
                <a href="/mi-cuenta" class="back-link">← Volver al panel</a>
                <h1>Editar Perfil</h1>
            </header>
            
            <div class="profile-center-wrapper">
                <ProfileForm client:only="react" />
            </div>
        </div>
    </main>

    <Footer />
</Layout>

<style>
    .account-subpage-container {
        padding: 150px 0 100px;
        min-height: 80vh;
        background-color: #f9f9f9;
        font-family: var(--font-paragraphs, sans-serif);
    }
    .subpage-header {
        margin-bottom: 3rem;
        text-align: center;
    }
    .back-link {
        color: #999;
        text-decoration: none;
        font-size: 0.9rem;
        margin-bottom: 1rem;
        display: inline-block;
    }
    .back-link:hover {
        color: var(--color-gold);
    }
    h1 {
        font-family: var(--font-titles, sans-serif);
        font-size: 3rem;
        color: var(--color-green);
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .profile-center-wrapper {
        display: flex;
        justify-content: center;
    }
</style>
