---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { PUBLIC_WP_URL } from '../../../lib/woocommerce';

export const prerender = false;

const { slug } = Astro.params;
const page = Number(Astro.url.searchParams.get('pagina') || 1);
const perPage = 12;

let category: any = null;
let posts: any[] = [];
let totalPages = 1;
let allCategories: any[] = [];

try {
  const catRes = await fetch(
    `${PUBLIC_WP_URL}/wp-json/wp/v2/categories?slug=${slug}&_embed`
  );
  if (catRes.ok) {
    const catData = await catRes.json();
    category = catData[0] || null;
  }

  if (!category) {
    return Astro.redirect('/blog');
  }

  const [postsRes, allCatsRes] = await Promise.all([
    fetch(`${PUBLIC_WP_URL}/wp-json/wp/v2/posts?categories=${category.id}&per_page=${perPage}&page=${page}&_embed&status=publish`),
    fetch(`${PUBLIC_WP_URL}/wp-json/wp/v2/categories?per_page=100&hide_empty=true`),
  ]);

  if (postsRes.ok) {
    posts = await postsRes.json();
    totalPages = Number(postsRes.headers.get('X-WP-TotalPages') || 1);
  }
  if (allCatsRes.ok) {
    allCategories = await allCatsRes.json();
  }
} catch (e) {
  console.error('Error fetching blog category:', e);
  return Astro.redirect('/blog');
}

const catName = category.name || slug;
const catDescription = category.description || '';
const totalCount = category.count || 0;
const bannerImg = category.acf?.banner_imagen || '';

const seoData = {
  title: `${catName} | Blog Winston & Harry`,
  description: catDescription || `Artículos de ${catName} — moda, tendencias y cuero artesanal colombiano.`,
  canonical: `https://winstonandharrystore.com/blog/categoria/${slug}`,
};
---

<Layout seoData={seoData} title={seoData.title} description={seoData.description}>
  <Header />

  <section class="cat-hero" style={bannerImg ? `--cat-bg: url('${bannerImg}')` : ''}>
    <div class="cat-hero__overlay"></div>
    <div class="cat-hero__content">
      <nav class="cat-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span>/</span>
        <a href="/blog">Blog</a>
        <span>/</span>
        <span>{catName}</span>
      </nav>
      <h1>{catName}</h1>
      {catDescription && <p class="cat-desc" set:html={catDescription} />}
      <p class="cat-count">{totalCount} {totalCount === 1 ? 'artículo' : 'artículos'}</p>
    </div>
  </section>

  {allCategories.filter((c: any) => c.id !== 1).length > 0 && (
    <section class="blog-filters">
      <div class="container">
        <div class="blog-filters__list">
          <a href="/blog" class="blog-filter-tag">Todos</a>
          {allCategories
            .filter((c: any) => c.id !== 1)
            .map((cat: any) => (
              <a
                href={`/blog/categoria/${cat.slug}`}
                class={`blog-filter-tag ${cat.slug === slug ? 'active' : ''}`}
              >
                {cat.name}
              </a>
            ))}
        </div>
      </div>
    </section>
  )}

  <section class="blog-grid-section">
    <div class="container">
      {posts.length === 0 ? (
        <div class="blog-empty">
          <p>No hay publicaciones en esta categoría aún.</p>
          <a href="/blog" class="btn-outline">Ver todos los artículos</a>
        </div>
      ) : (
        <div class="blog-grid">
          {posts.map((post: any) => {
            const img = post._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
            const excerpt = post.excerpt?.rendered?.replace(/<[^>]*>/g, '').slice(0, 120) + '...';
            const date = new Date(post.date).toLocaleDateString('es-CO', {
              year: 'numeric', month: 'long', day: 'numeric',
            });
            return (
              <article class="blog-card reveal-on-scroll">
                <a href={`/blog/${post.slug}`} class="blog-card__image-wrap">
                  {img && <img src={img} alt={post.title.rendered.replace(/<[^>]*>/g, '')} loading="lazy" />}
                  <span class="blog-card__cat">{catName}</span>
                </a>
                <div class="blog-card__body">
                  <time class="blog-card__date">{date}</time>
                  <h2 class="blog-card__title">
                    <a href={`/blog/${post.slug}`} set:html={post.title.rendered} />
                  </h2>
                  <p class="blog-card__excerpt">{excerpt}</p>
                  <a href={`/blog/${post.slug}`} class="btn blog-card__cta">Leer más</a>
                </div>
              </article>
            );
          })}
        </div>
      )}

      {totalPages > 1 && (
        <nav class="blog-pagination" aria-label="Paginación">
          {page > 1 && (
            <a href={`/blog/categoria/${slug}?pagina=${page - 1}`} class="blog-pag-btn">← Anterior</a>
          )}
          <span class="blog-pag-info">Página {page} de {totalPages}</span>
          {page < totalPages && (
            <a href={`/blog/categoria/${slug}?pagina=${page + 1}`} class="blog-pag-btn">Siguiente →</a>
          )}
        </nav>
      )}
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .cat-hero { position: relative; min-height: 380px; background: var(--cat-bg, linear-gradient(135deg, #155338, #0a2b1c)) center / cover no-repeat; display: flex; align-items: center; justify-content: center; text-align: center; padding: 4rem 2rem; }
  .cat-hero__overlay { position: absolute; inset: 0; background: rgba(21, 83, 56, 0.72); }
  .cat-hero__content { position: relative; z-index: 1; color: #efefef; max-width: 700px; }
  .cat-hero__content h1 { font-size: clamp(2rem, 5vw, 3.5rem); color: #efefef; letter-spacing: 8px; text-transform: uppercase; margin-bottom: 0.75rem; }
  .cat-desc { font-size: 0.85rem; color: rgba(239,239,239,0.75); margin-bottom: 0.75rem; line-height: 1.7; }
  .cat-count { font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #b1915f; }
  .cat-breadcrumb { display: flex; align-items: center; justify-content: center; gap: 0.5rem; font-size: 0.7rem; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(239,239,239,0.55); margin-bottom: 1.5rem; }
  .cat-breadcrumb a { color: rgba(239,239,239,0.55); transition: color 0.2s; }
  .cat-breadcrumb a:hover { color: #b1915f; }
  .blog-filters { padding: 2rem 0; border-bottom: 1px solid rgba(18,18,18,0.08); }
  .blog-filters__list { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
  .blog-filter-tag { padding: 0.4rem 1.2rem; border: 1px solid #155338; color: #155338; font-size: 0.72rem; letter-spacing: 1.5px; text-transform: uppercase; transition: var(--transition, all 0.3s ease); }
  .blog-filter-tag:hover, .blog-filter-tag.active { background: #155338; color: #efefef; }
  .blog-grid-section { padding: 5rem 0; }
  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
  .blog-card { display: flex; flex-direction: column; background: #fff; border: 1px solid rgba(18,18,18,0.08); transition: box-shadow 0.3s ease; }
  .blog-card:hover { box-shadow: 0 8px 32px rgba(21,83,56,0.12); }
  .blog-card__image-wrap { position: relative; overflow: hidden; aspect-ratio: 16/9; display: block; background: #f0ece6; }
  .blog-card__image-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .blog-card:hover .blog-card__image-wrap img { transform: scale(1.04); }
  .blog-card__cat { position: absolute; top: 1rem; left: 1rem; background: #b1915f; color: #fff; font-size: 0.65rem; letter-spacing: 1.5px; text-transform: uppercase; padding: 0.3rem 0.75rem; }
  .blog-card__body { padding: 1.5rem; display: flex; flex-direction: column; flex: 1; gap: 0.5rem; }
  .blog-card__date { font-size: 0.7rem; color: #b1915f; letter-spacing: 1px; text-transform: uppercase; }
  .blog-card__title { font-size: 1rem; color: #155338; letter-spacing: 1px; line-height: 1.4; margin: 0; }
  .blog-card__title a { color: inherit; transition: color 0.2s; }
  .blog-card__title a:hover { color: #b1915f; }
  .blog-card__excerpt { font-size: 0.8rem; color: #555; flex: 1; line-height: 1.7; }
  .blog-card__cta { align-self: flex-start; margin-top: 0.5rem; font-size: 0.72rem; padding: 0.55rem 1.4rem; }
  .blog-pagination { display: flex; align-items: center; justify-content: center; gap: 1.5rem; margin-top: 4rem; }
  .blog-pag-btn { border: 1px solid #155338; color: #155338; padding: 0.5rem 1.5rem; font-size: 0.72rem; letter-spacing: 1px; text-transform: uppercase; transition: var(--transition, all 0.3s ease); }
  .blog-pag-btn:hover { background: #155338; color: #efefef; }
  .blog-pag-info { font-size: 0.72rem; color: #888; letter-spacing: 1px; }
  .blog-empty { text-align: center; padding: 5rem 0; display: flex; flex-direction: column; align-items: center; gap: 1.5rem; color: #888; font-size: 0.9rem; }
  .btn-outline { display: inline-block; border: 1px solid #155338; color: #155338; padding: 0.6rem 1.5rem; font-size: 0.72rem; letter-spacing: 1.5px; text-transform: uppercase; transition: var(--transition, all 0.3s ease); }
  .btn-outline:hover { background: #155338; color: #efefef; }
  @media (max-width: 1024px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) {
    .cat-hero { min-height: 280px; }
    .blog-grid { grid-template-columns: 1fr; }
    .blog-grid-section { padding: 3rem 0; }
  }
</style>
